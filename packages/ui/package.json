{
  "name": "ui-kit",
  "version": "0.0.1",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/uikit.umd.cjs",
  "module": "./dist/uikit.js",
  "types": "./dist/uikit.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "build:withcss": "pnpm generate:safelist && tsc && vite build && pnpm generate:css",
    "generate:safelist": "vite-node scripts/generate-safelist.ts",
    "generate:css": "tailwindcss -i ./index.css -o ./dist/style.css"
  },
  "exports": {
    ".": {
      "import": "./dist/uikit.js",
      "require": "./dist/uikit.umd.cjs",
      "types": "./dist/uikit.d.ts"
    },
    "./safelist.css": "./src/generated/safelist.css",
    "./style.css": "./dist/style.css"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@busbud/tailwind-buddy": "workspace:*",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-node": "^1.6.1",
    "vite-plugin-dts": "^3.8.1"
  }
}
