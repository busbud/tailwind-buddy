{
  "name": "ui-kit",
  "version": "0.0.1",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "tailwind.config.js",
    "src"
  ],
  "main": "./dist/uikit.umd.cjs",
  "module": "./dist/uikit.js",
  "types": "./dist/uikit.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "build:withcss": "tsc && vite build && pnpm generate:css",
    "generate:css": "tailwindcss -i ./index.css -o ./dist/style.css",
    "prepare": "pnpm build"
  },
  "exports": {
    ".": {
      "import": "./dist/uikit.js",
      "require": "./dist/uikit.umd.cjs",
      "types": "./dist/uikit.d.ts"
    },
    "./tailwind.config": {
      "import": "./tailwind.config.ts",
      "require": "./tailwind.config.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@busbud/tailwind-buddy": "workspace:*",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.1"
  },
  "peerDependencies": {
    "@busbud/tailwind-buddy": "workspace:*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0",
    "tailwindcss": "^3"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  }
}
